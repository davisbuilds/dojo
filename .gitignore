# Claude Code — ignore user-specific subdirs; settings.json is tracked.
# `.claude/skills` is a generated symlink -> ../skills (regenerated per clone
# by scripts/gen_harness_adapters.py), so ignore it as a file or directory.
.claude/skills
.claude/commands
.claude/todos/
.claude/projects/

# skill-standardizer backup snapshots
.skill-standardizer/backups/
skills-lock.json

# Playwright CLI runtime snapshot dumps (written under the CWD wherever the CLI
# runs — repo root, the skill dir, or output/playwright/<label>/ — never part of
# a skill). Repo-wide so no run leaves stray snapshots tracked.
**/.playwright-cli/
