{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-start-skill-catalog.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use-validate-skill.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-tool-use-regen-manifest.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/post-tool-use-validate-implementation-plan.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop-hook-git-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop-hook-skill-structure.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop-hook-session-learnings.sh"
          }
        ]
      }
    ]
  }
}
